# ============================================================================
# ASvLLM Project - .gitignore
# Comprehensive file exclusion for git repository
# Last updated: April 2026
# ============================================================================

# ============================================================================
# RESULTS & DATA (Large files, generated during experiments)
# ============================================================================

# Log files and results
logs/
*.csv
!requirements.csv
master_results.csv
master_run_results.csv
run_summary.csv
*.log

# Generated plots and figures
figures/
*.png
*.jpg
*.jpeg
*.gif
eda_*.png
comparison_*.png
interaction_heatmap_*.png
eval_*.png
evaluation_*.png
ablation_*.png

# Temporary image files
temp.jpg
temp_for_api.jpg
temp_vision.jpg
temp*.png
temp*.jpg

# Study results
study_results/
screenshots/
screenshots_*/old/

# ============================================================================
# PAPER PLANNING & DOCUMENTATION (Optional - keep or remove based on preference)
# ============================================================================

# Paper drafts and planning documents
PAPER_PLAN.md
IMPLEMENTATION_SUMMARY.md
STATUS_REPORT.md
ANALYSIS_AUDIT.md
REFACTORING_SUMMARY.md
STAGE1_QUICKSTART.py
paper_draft.docx
paper_draft.tex
manuscript.pdf
supplementary_materials/

# Meeting notes and research logs
notes/
research_log.txt
TODO.md
WORKLOG.md

# ============================================================================
# TEMPORARY FILES & BACKUPS
# ============================================================================

# Backup files
*_OLD.md
*.bak
*.backup
*~
~*bak

# Temporary testing files
try.py
test_*.py
debug_*.py
tmp/
temp/
cache/

# ============================================================================
# DIAGRAMS & VISUALIZATIONS
# ============================================================================

# Mermaid diagrams and flowcharts
*.mmd
*.mermaid
diagrams/
architecture_diagram.png
pipeline_diagram.png
*.graphviz
*.dot

# PowerPoint/Slides
*.ppt
*.pptx
presentation/

# ============================================================================
# PYTHON & ENVIRONMENT
# ============================================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environment
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Poetry / Pipenv
poetry.lock
Pipfile.lock

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints

# pyenv
.pyenv

# ============================================================================
# IDE & EDITOR FILES
# ============================================================================

# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr
.project
.pydevproject

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vim

# Emacs
*~
\#*\#
.\#*

# Atom
.atom

# ============================================================================
# ENVIRONMENT & SECRETS (CRITICAL - NEVER COMMIT API KEYS!)
# ============================================================================

# CRITICAL: Environment variables with API keys and credentials
# NEVER commit .env files - they contain sensitive information!
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# Credentials and keys (NEVER commit)
*.pem
*.key
*.crt
*.p12
*.pfx
*.der
*.pub

# AWS/Cloud credentials
aws_credentials
credentials
credentials.json

# API configuration files
api_config
api_keys.txt
secrets.txt
secrets/
.secrets/

# ============================================================================
# OS FILES
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory
.Trash-*

# ============================================================================
# IDE TEMPORARY FILES
# ============================================================================

*.bak
*.tmp
*.temp
*.swp
*.swo
*~

# ============================================================================
# DEBUGGING & TESTING
# ============================================================================

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/

# Debugging
debug.log
*.stacktrace

# ============================================================================
# BUILD & DIST
# ============================================================================

build/
dist/
*.egg-info/
*.egg
*.whl

# ============================================================================
# MISC
# ============================================================================

# Temporary files
*.tmp
*.temp
*.bak
~*

# OS-specific files
.DS_Store
Thumbs.db

# Project-specific temporary files
temp/
tmp/
test_output/
cache/

# ============================================================================
# OPTIONAL: COMMENT OUT IF YOU WANT THESE IN GIT
# ============================================================================

# If you want to version control paper drafts, uncomment:
# !PAPER_PLAN.md
# !IMPLEMENTATION_SUMMARY.md
# !STATUS_REPORT.md

# If you want to version control diagrams, uncomment:
# !diagrams/
# !*.mmd
# !architecture_diagram.png

# ============================================================================
# EXCEPTIONS (Files to ALWAYS track despite earlier patterns)
# ============================================================================

# Documentation (ALWAYS INCLUDE)
!README.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!CHANGELOG.md
!CONTRIBUTORS.md
!QUICK_REFERENCE.md
!LICENSE
!requirements.txt

# Source code and configuration (ALWAYS INCLUDE)
!*.py
!prompts_generator/
!*.yml
!*.yaml

# Important reference files (ALWAYS INCLUDE)
!.gitignore
!.gitattributes
